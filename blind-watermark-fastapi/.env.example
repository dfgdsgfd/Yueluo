# Internal authentication. When set, clients must send X-Internal-API-Key.
BLIND_WATERMARK_API_KEY=change_me_internal_only

# Bind these with uvicorn, for example:
# uv run python -m blind_watermark_fastapi
BLIND_WATERMARK_HOST=0.0.0.0
BLIND_WATERMARK_PORT=8090
BLIND_WATERMARK_MAX_IMAGE_BYTES=10485760
BLIND_WATERMARK_MAX_WORKERS=2

# Public options used by the guofei9987/blind_watermark official example.
BLIND_WATERMARK_PASSWORD_WM=1
BLIND_WATERMARK_PASSWORD_IMG=1

# Upstream screenshot recovery searches crop/scale candidates against the
# complete watermarked reference image. Higher values trade CPU time for accuracy.
BLIND_WATERMARK_RECOVERY_SEARCH_NUM=80
