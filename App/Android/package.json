{
  "name": "yuem-android",
  "version": "1.0.0",
  "private": true,
  "description": "月梦-快速版 Android native shell",
  "scripts": {
    "sync": "cap sync android",
    "open": "cap open android",
    "build:debug": "cd android && ./gradlew assembleDebug",
    "build:release": "node scripts/build-release-container.mjs",
    "build:release:native": "node scripts/build-release.mjs",
    "signing:generate": "node scripts/generate-signing-key.mjs",
    "verify:release": "node scripts/verify-release.mjs"
  },
  "dependencies": {
    "@capacitor/android": "8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/browser": "8.0.3",
    "@capacitor/core": "8.4.1",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/keyboard": "8.0.5",
    "@capacitor/network": "8.0.1",
    "@capacitor/share": "8.0.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2"
  },
  "devDependencies": {
    "@capacitor/assets": "3.0.5",
    "@capacitor/cli": "8.4.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=25 <26"
  }
}
