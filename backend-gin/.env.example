# backend-gin environment example
#
# Copy this file to backend-gin/.env for local deployment, or provide the same
# keys via the process environment. Process environment variables always take
# precedence over values loaded from .env files.
#
# Loading order:
# 1. GIN_ENV_FILE or ENV_FILE, if set
# 2. backend-gin/.env
# 3. .env in the repository root
#
# This template is Go-Gin only. Keep operational notes and generated runtime
# paths out of .env files. Keep real secrets out of version control.

# Server
GIN_PORT=3001
# GIN_MODE is consumed by the Gin framework before application code starts.
# Use Gin's supported values: debug, release, or test.
GIN_MODE=debug
# APP_ENV controls Yuem business/runtime behavior such as secure cookies.
APP_ENV=development
CLIENT_IP_HEADERS=X-Forwarded-For,X-Real-IP,CF-Connecting-IP

# Console logging threshold. Set LOG_LEVEL=error to keep non-error messages out
# of container/stdout logs. Request logs follow this value unless overridden by
# REQUEST_LOG_LEVEL below.
LOG_LEVEL=info

# Error file logging writes only error and above to LOG_FILE_DIR/YYYY-MM-DD-error.log.
# Files are rotated daily and old matching error logs are removed automatically.
LOG_FILE_ENABLED=true
LOG_FILE_DIR=logs
LOG_FILE_RETENTION_DAYS=7

# Request logging level threshold. Messages at or above this level are logged.
#   debug — log everything (including silent paths like health checks)
#   info  — log normal requests, skip silent paths (default)
#   warn  — only 4xx and above
#   error — only 5xx
REQUEST_LOG_LEVEL=info

# Comma-separated path prefixes whose request logs are marked as debug level
# instead of info. This means they are only visible when REQUEST_LOG_LEVEL=debug.
# Default covers noisy WebSocket upgrades and client-side maintenance polling.
REQUEST_LOG_SILENCE=/api/im/ws,/api/maintenance/status

# Database
# DATABASE_URL is authoritative when set.
# MySQL: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/xiaoshiliu?schema=public

# Split database variables are used only when DATABASE_URL is empty.
DB_DRIVER=postgresql
DB_HOST=localhost
DB_USER=user
DB_PASSWORD=change_me
DB_NAME=xiaoshiliu
DB_PORT=5432

# Connection pool and SQL options. DB_AUTO_MIGRATE lets GORM create/update
# application tables on startup so deployment does not require manual SQL.
DB_POOL_SIZE=10
DB_MAX_IDLE_CONNS=0
DB_CONN_MAX_LIFETIME_MS=0
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=60000
DB_CHARSET=utf8mb4
DB_TIMEZONE=+08:00
DB_SCHEMA=public
DB_SSL_MODE=disable
DB_STATEMENT_TIMEOUT=0
DB_LOCK_TIMEOUT=0
# GORM SQL logger level. Defaults to LOG_LEVEL; set DB_LOG_LEVEL=silent to hide
# all ORM SQL logs or error to keep only SQL errors.
DB_LOG_LEVEL=warn
# Treat GORM record-not-found results as normal empty-query misses in SQL logs.
DB_IGNORE_RECORD_NOT_FOUND_ERROR=true
DB_PREPARE_STMT=false
DB_CREATE_BATCH_SIZE=0
DB_SKIP_DEFAULT_TRANSACTION=false
DB_AUTO_MIGRATE=true

# Auth
JWT_SECRET=change_me_to_a_long_random_secret
# Token lifetimes are seconds. Legacy d/h/m/s suffix values remain accepted.
JWT_EXPIRES_IN=3600
# Admin console access token lifetime. Defaults to JWT_EXPIRES_IN when unset.
ADMIN_JWT_EXPIRES_IN=12h
REFRESH_TOKEN_EXPIRES_IN=7776000

# API and public URLs
API_BASE_URL=http://localhost:3001/api
API_TIMEOUT=30000
FRONTEND_URL=http://localhost:5173
LOCAL_BASE_URL=http://localhost:3001

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Guest access settings. Set note/video to false when logged-out visitors should
# be allowed to read public home feed, hot categories, post details, and video
# center data.
GUEST_ACCESS_RESTRICTED=false
GUEST_ACCESS_NOTE_RESTRICTED=false
GUEST_ACCESS_VIDEO_RESTRICTED=false
GUEST_ACCESS_ADMIN_RESTRICTED=true

# Redis and queues. Admin login failures are counted by client IP in Redis;
# after 5 invalid credential attempts the IP is locked for 30 minutes. The
# application keeps a process-local fallback when Redis is temporarily down.
QUEUE_ENABLED=false
REDIS_ADDR=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=0
REDIS_MIN_IDLE_CONNS=0
REDIS_CACHE_ENABLED=true
REDIS_CACHE_COMMAND_TIMEOUT_MS=50
REDIS_CACHE_DEFAULT_TTL_SECONDS=30
REDIS_CACHE_L1_TTL_SECONDS=2
REDIS_CACHE_L1_MAX_ENTRIES=0
QUEUE_IP_LOCATION_CONCURRENCY=5
QUEUE_CONTENT_AUDIT_CONCURRENCY=3
QUEUE_GENERAL_TASK_CONCURRENCY=5
QUEUE_AI_TASK_CONCURRENCY=2
QUEUE_VIDEO_TRANSCODING_CONCURRENCY=1
QUEUE_BATCH_NOTE_CREATE_CONCURRENCY=3
QUEUE_AUDIT_LOG_CONCURRENCY=2
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=1000

# Persistent access and security audit logs. Request handlers only enqueue into an
# in-process buffer; Asynq batch workers write PostgreSQL rows.
ACCESS_LOG_ENABLED=true
ACCESS_LOG_SCOPE=key
ACCESS_LOG_BEHAVIORS=post_view,feed_view,search,post_create,draft_save,post_update,post_delete,draft_delete,comment_create,like,collect,follow,image_upload,video_upload,attachment_upload,apk_upload,upload,admin_access
ACCESS_LOG_RETENTION_HOURS=8760
ACCESS_LOG_BUFFER_SIZE=4096
ACCESS_LOG_BATCH_SIZE=100
ACCESS_LOG_FLUSH_INTERVAL_MS=1000
SECURITY_AUDIT_LOG_ENABLED=true
SECURITY_AUDIT_LOG_RETENTION_HOURS=8760

# GeoIP country lookup
GEOIP_COUNTRY_MMDB_PATH=data/geoip/Country.mmdb
GEOIP_COUNTRY_MMDB_URL=https://github.com/Loyalsoldier/geoip/releases/latest/download/Country.mmdb
GEOIP_COUNTRY_MMDB_SHA256_URL=https://github.com/Loyalsoldier/geoip/releases/latest/download/Country.mmdb.sha256sum

# System logs and performance metrics are written to Redis.
SYSTEM_LOG_ENABLED=true
SYSTEM_LOG_RETENTION_HOURS=168
PERFORMANCE_METRICS_ENABLED=true
PERFORMANCE_METRICS_RETENTION_HOURS=24
PERFORMANCE_METRICS_BUCKET_SECONDS=300
PERFORMANCE_SAMPLE_INTERVAL_SECONDS=300
SLOW_REQUEST_THRESHOLD_MS=1000
SLOW_QUERY_THRESHOLD_MS=500

# Upload storage
UPLOAD_ROOT=uploads
LOCAL_UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE=50mb
UPLOAD_TEMP_DIR=uploads/tmp
UPLOAD_TEMP_CLEANUP_INTERVAL=15m
UPLOAD_TEMP_RETENTION=24h
PROTECTED_PACKAGE_RETENTION=2h
AVATAR_UPLOAD_DIR=uploads/avatar
BANNER_UPLOAD_DIR=uploads/banner
DELETE_POST_UPLOADS_ON_DELETE=false
FILE_SIGNING_SECRET=
FILE_SIGNING_TTL_SECONDS=900
IMAGE_MAX_SIZE=10mb
VIDEO_MAX_SIZE=100mb
ATTACHMENT_MAX_SIZE=50mb
IMAGE_UPLOAD_STRATEGY=imagehost
VIDEO_UPLOAD_STRATEGY=local
ATTACHMENT_UPLOAD_STRATEGY=local
IMAGE_LOCAL_UPLOAD_DIR=uploads/images
VIDEO_UPLOAD_DIR=uploads/videos
VIDEO_LOCAL_UPLOAD_DIR=uploads/videos
VIDEO_COVER_DIR=uploads/covers
ATTACHMENT_LOCAL_UPLOAD_DIR=uploads/attachments

# Image host
IMAGEHOST_API_URL=https://api.example.com/upload
IMAGEHOST_TIMEOUT=60000

# Cloudflare R2 / S3-compatible storage
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_ACCOUNT_ID=
R2_REGION=auto
# R2_PUBLIC_URL=

# Video chunk uploads
VIDEO_CHUNK_TEMP_DIR=uploads/chunks
VIDEO_CHUNK_SIZE=3145728
VIDEO_CHUNK_CLEANUP_INTERVAL=1800000
VIDEO_CHUNK_EXPIRE_TIME=7200000

# Video transcoding
VIDEO_TRANSCODING_ENABLED=false
FFMPEG_PATH=/app/bin/ffmpeg
FFPROBE_PATH=/app/bin/ffprobe
VIDEO_TRANSCODING_MAX_THREADS=4
VIDEO_TRANSCODING_MAX_CONCURRENT=1
VIDEO_DASH_OUTPUT_FORMAT={date}/{userId}/{timestamp}
DASH_SEGMENT_DURATION=4
DASH_MIN_BITRATE=500
DASH_MAX_BITRATE=5000
DASH_RESOLUTIONS=1920x1080:1800,1280x720:1500,854x480:900,640x360:500
ORIGINAL_VIDEO_MAX_BITRATE=2400
DELETE_ORIGINAL_VIDEO=false
FFMPEG_PRESET=medium
FFMPEG_PROFILE=main
FFMPEG_CRF=
FFMPEG_GOP_SIZE=
FFMPEG_B_FRAMES=
FFMPEG_REF_FRAMES=
FFMPEG_COMPLEXITY=
FFMPEG_AUDIO_BITRATE=128
FFMPEG_AUDIO_SAMPLE_RATE=48000
FFMPEG_PIXEL_FORMAT=yuv420p
FFMPEG_HARDWARE_ACCEL=false
FFMPEG_HARDWARE_ACCEL_TYPE=

# WebP and watermarks
WEBP_ENABLE_CONVERSION=true
WEBP_QUALITY=85
AVATAR_WEBP_QUALITY=75
WEBP_METHOD=4
WEBP_CONVERT_JPEG=true
WEBP_CONVERT_PNG=true
WEBP_KEEP_ORIGINAL=false
WEBP_MAX_WIDTH=
WEBP_MAX_HEIGHT=
WEBP_LOSSLESS=false
WEBP_ALPHA_QUALITY=100

# Invisible watermark. If the secret is empty, FILE_SIGNING_SECRET is used.
HIDDEN_WATERMARK_SECRET=
HIDDEN_WATERMARK_ENABLED=true
HIDDEN_WATERMARK_PROTECTED_ONLY=true
# Set the runtime engine in the admin panel or with HIDDEN_WATERMARK_ENGINE.
# local uses the built-in Go watermark_zero pipeline. remote calls the internal
# FastAPI blind-watermark service below. HTTP and self-signed HTTPS are supported.
HIDDEN_WATERMARK_ENGINE=auto
HIDDEN_WATERMARK_REMOTE_URL=http://127.0.0.1:8090
HIDDEN_WATERMARK_REMOTE_API_KEY=
HIDDEN_WATERMARK_REMOTE_SKIP_TLS_VERIFY=false
# Public options from the guofei9987/blind_watermark official example. The
# library defaults for block_shape, d1 and d2 remain internal and unchanged.
HIDDEN_WATERMARK_REMOTE_PASSWORD_WM=1
HIDDEN_WATERMARK_REMOTE_PASSWORD_IMG=1

WATERMARK_ENABLED=false
WATERMARK_TYPE=text
WATERMARK_TEXT=
WATERMARK_FONT_SIZE=24
WATERMARK_FONT_PATH=
WATERMARK_IMAGE_PATH=
WATERMARK_OPACITY=50
WATERMARK_POSITION=9
WATERMARK_POSITION_MODE=grid
WATERMARK_PRECISE_X=0
WATERMARK_PRECISE_Y=0
WATERMARK_IMAGE_RATIO=4
WATERMARK_COLOR=#ffffff
WATERMARK_TILE_MODE=false

USERNAME_WATERMARK_ENABLED=false
USERNAME_WATERMARK_FONT_SIZE=20
USERNAME_WATERMARK_FONT_PATH=
USERNAME_WATERMARK_OPACITY=70
USERNAME_WATERMARK_POSITION=7
USERNAME_WATERMARK_POSITION_MODE=grid
USERNAME_WATERMARK_PRECISE_X=20
USERNAME_WATERMARK_PRECISE_Y=20
USERNAME_WATERMARK_COLOR=#ffffff
USERNAME_WATERMARK_TEXT=@username

# Email
EMAIL_ENABLED=false
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=Yuem

# Notification channels
NOTIFICATION_EMAIL_ENABLED=false
SYSTEM_NOTIFICATION_EMAIL_ENABLED=false
DISCORD_WEBHOOK_ENABLED=false
DISCORD_WEBHOOK_URL=
DISCORD_SITE_NAME=Yuem
DISCORD_SITE_URL=http://localhost:5173

# OAuth2
OAUTH2_ENABLED=false
OAUTH2_ONLY_LOGIN=false
OAUTH2_LOGIN_URL=
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_REDIRECT_URI=
OAUTH2_REDIRECT_BASE_URL=http://localhost:3000
OAUTH2_CALLBACK_PATH=/api/auth/oauth2/callback
# Native ticket bridge callback. The legacy PKCE app-token callback remains
# xsewebfast://oauth/callback internally for installed older APKs.
OAUTH2_APP_CALLBACK_URL=xsewebfast://auth-return
# Optional: multiple native ticket bridge callbacks, one full callback per app.
# Backend system setting oauth2_app_callback_urls overrides this after it is saved.
# OAUTH2_APP_CALLBACK_URLS=xsewebfast://auth-return,yuempro://auth-return
OAUTH2_DPOP_ENABLED=false

# Balance center
BALANCE_API_URL=https://user.yuelk.com
BALANCE_API_KEY=
BALANCE_API_TIMEOUT=10s
BALANCE_EXCHANGE_RATE_IN=1.0
BALANCE_EXCHANGE_RATE_OUT=1.0

# Creator center
CREATOR_PLATFORM_FEE_RATE=0
CREATOR_WITHDRAW_ENABLED=true
CREATOR_MIN_WITHDRAW_AMOUNT=10
CREATOR_EXTENDED_EARNINGS_ENABLED=false
CREATOR_EARNINGS_PER_VIEW=0.01
CREATOR_EARNINGS_PER_LIKE=0.05
CREATOR_EARNINGS_PER_COLLECT=0.10
CREATOR_EARNINGS_PER_COMMENT=0.02
CREATOR_EARNINGS_PER_FOLLOWER=0.20
CREATOR_DAILY_EXTENDED_EARNINGS_CAP=0

# Content audit
CONTENT_AUDIT_ENABLED=false
DIFY_API_URL=http://aish.example.com/v1/chat-messages
DIFY_API_KEY=

# Geetest
GEETEST_ENABLED=false
GEETEST_CAPTCHA_ID=
GEETEST_CAPTCHA_KEY=
GEETEST_API_SERVER=https://gcaptcha4.geetest.com

# PyVideo and video center
PYVIDEO_API_KEY=
VIDEO_CENTER_API_KEY=
PYVIDEO_UPSTREAM_URL=https://v.example.com

# Verification requests
VERIFICATION_COLLECT_SENSITIVE_INFO=false

# Chat and IM
# IM_MODE controls WebSocket connection mode:
#   direct (default) — clients call /api/im/session and connect to upstream directly
#   proxy             — clients connect to the local Gin /api/im/ws hub
IM_MODE=direct
CHAT_WS_ENABLED=false
CHAT_WS_BASE_URL=https://ws-im.yuelk.com:29443
CHAT_WS_PROVISION_SECRET=
CHAT_WS_ENCRYPTION_KEY=
CHAT_WS_TICKET_TTL=60
CHAT_WS_HTTP_TIMEOUT=10000
CHAT_MESSAGE_MAX_LENGTH=2000
IM_BASE=https://ws-im.yuelk.com:29443
IM_HMAC_SECRET=
IM_MESSAGE_KEY=

# Access block
ACCESS_BLOCK_DISABLED=false
ACCESS_BLOCK_VERSION_POLL_INTERVAL=5s
ACCESS_BLOCK_IMPORT_DISABLED=false
ACCESS_BLOCK_IMPORT_MIN_INTERVAL_SECONDS=300
ACCESS_BLOCK_IMPORT_HTTP_TIMEOUT_SECONDS=10
ACCESS_BLOCK_IMPORT_MAX_BYTES=2097152
ACCESS_BLOCK_IMPORT_SCHEDULER_INTERVAL_SECONDS=60
ACCESS_BLOCK_IMPORT_DEFAULT_INTERVAL_SECONDS=3600

# Media and debug
ALLOWED_MEDIA_DOMAINS=
RECOMMENDATION_DEBUG=false
SWAGGER_DOCS_PATH=swagger-MYQD6LuH0heYgcK5DT10Al00dj6OW8Wc
JWT_TEST_TOKEN_PATH=jwt-MYQD6LuH0heYgcK5DT10Al00dj6OW8Wc
