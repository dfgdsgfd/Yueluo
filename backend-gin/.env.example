# backend-gin local environment
# Generated from the previous Express .env values and mapped to Go-Gin keys.
# This file is ignored by git; keep real secrets out of tracked files.

# Server
APP_ENV=production
GIN_PORT=3001
GIN_MODE=release
CLIENT_IP_HEADERS=X-Real-IP,X-Forwarded-For,CF-Connecting-IP,X-Custom-Real-IP

# Request logging level threshold. Messages at or above this level are logged.
#   debug — log everything (including silent paths like health checks)
#   info  — log normal requests, skip silent paths (default)
#   warn  — only 4xx and above
#   error — only 5xx
REQUEST_LOG_LEVEL=error
LOG_FILE_ENABLED=true
LOG_LEVEL=error
REQUEST_LOG_LEVEL=error

LOG_FILE_ENABLED=true
LOG_FILE_DIR=logs
LOG_FILE_RETENTION_DAYS=7

# Comma-separated path prefixes whose request logs are marked as debug level
# instead of info. This means they are only visible when REQUEST_LOG_LEVEL=debug.
# Default covers noisy WebSocket upgrades and client-side maintenance polling.
REQUEST_LOG_SILENCE=/api/im/ws,/api/maintenance/status,/api/im/session


# Database
DATABASE_URL=postgresql://Yueluo:rASQKa8NndsQkM8a@1Panel-postgresql-AbOE:5432/Yueluo
DB_DRIVER=postgresql
DB_HOST=1Panel-postgresql-AbOE
DB_USER=Yueluo
DB_PASSWORD=rASQKa8NndsQkM8a
DB_NAME=Yueluo
DB_PORT=5432
DB_POOL_SIZE=20
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MS=1800000
DB_CONNECTION_TIMEOUT=300000
DB_IDLE_TIMEOUT=60000
DB_CHARSET=utf8mb4
DB_TIMEZONE=+08:00
DB_SCHEMA=public
DB_SSL_MODE=disable
DB_STATEMENT_TIMEOUT=60000
DB_LOCK_TIMEOUT=15000
# GORM SQL logger level. Defaults to LOG_LEVEL; set DB_LOG_LEVEL=silent to hide
# all ORM SQL logs or error to keep only SQL errors.
DB_LOG_LEVEL=warn
DB_IGNORE_RECORD_NOT_FOUND_ERROR=true
DB_PREPARE_STMT=false
DB_CREATE_BATCH_SIZE=500
DB_SKIP_DEFAULT_TRANSACTION=true



# Auth
JWT_SECRET=3bddaef4ceaf63f08ab23f6a62d0916a
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_EXPIRES_IN=2592000
ADMIN_JWT_EXPIRES_IN=24h

# API and public URLs
API_BASE_URL=https://yueluo.yuemoxi.cn/api
API_TIMEOUT=30000
FRONTEND_URL=https://yueluo.yuemoxi.cn
LOCAL_BASE_URL=https://yueluo.yuemoxi.cn

# CORS
CORS_ORIGINS=https://yueluo.yuemoxi.cn

# Redis and queues
QUEUE_ENABLED=true
REDIS_ADDR=1Panel-redis-rhH5:6379
REDIS_HOST=1Panel-redis-rhH5
REDIS_PORT=6379
REDIS_PASSWORD=redis_z2mB3b
REDIS_DB=0
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5
REDIS_CACHE_ENABLED=true
REDIS_CACHE_COMMAND_TIMEOUT_MS=200
REDIS_CACHE_DEFAULT_TTL_SECONDS=120
REDIS_CACHE_L1_TTL_SECONDS=3
REDIS_CACHE_L1_MAX_ENTRIES=0


QUEUE_IP_LOCATION_CONCURRENCY=2
QUEUE_CONTENT_AUDIT_CONCURRENCY=1
QUEUE_GENERAL_TASK_CONCURRENCY=2
QUEUE_VIDEO_TRANSCODING_CONCURRENCY=1
QUEUE_BATCH_NOTE_CREATE_CONCURRENCY=3
QUEUE_AUDIT_LOG_CONCURRENCY=2
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=1000

# Persistent access and security audit logs. Request handlers only enqueue into an
# in-process buffer; Asynq batch workers write PostgreSQL rows.
ACCESS_LOG_ENABLED=true
ACCESS_LOG_SCOPE=key
ACCESS_LOG_BEHAVIORS=post_view,feed_view,search,post_create,draft_save,post_update,post_delete,draft_delete,comment_create,like,collect,follow,image_upload,video_upload,attachment_upload,apk_upload,upload
ACCESS_LOG_RETENTION_HOURS=8760
ACCESS_LOG_BUFFER_SIZE=4096
ACCESS_LOG_BATCH_SIZE=100
ACCESS_LOG_FLUSH_INTERVAL_MS=1000
SECURITY_AUDIT_LOG_ENABLED=true
SECURITY_AUDIT_LOG_RETENTION_HOURS=8760

# GeoIP country lookup
GEOIP_COUNTRY_MMDB_PATH=data/geoip/Country.mmdb
GEOIP_COUNTRY_MMDB_URL=https://github.com/Loyalsoldier/geoip/releases/latest/download/Country.mmdb
GEOIP_COUNTRY_MMDB_SHA256_URL=https://github.com/Loyalsoldier/geoip/releases/latest/download/Country.mmdb.sha256sum


# Upload storage
UPLOAD_ROOT=uploads
LOCAL_UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE=2048mb
UPLOAD_TEMP_DIR=uploads/tmp
UPLOAD_TEMP_CLEANUP_INTERVAL=15m
UPLOAD_TEMP_RETENTION=24h
PROTECTED_PACKAGE_RETENTION=2h
AVATAR_UPLOAD_DIR=uploads/avatar
BANNER_UPLOAD_DIR=uploads/banner
IMAGE_MAX_SIZE=50mb
DELETE_POST_UPLOADS_ON_DELETE=true
VIDEO_MAX_SIZE=2048mb
ATTACHMENT_MAX_SIZE=50mb
IMAGE_UPLOAD_STRATEGY=local
VIDEO_UPLOAD_STRATEGY=local
ATTACHMENT_UPLOAD_STRATEGY=local
IMAGE_LOCAL_UPLOAD_DIR=uploads/images
VIDEO_UPLOAD_DIR=uploads/videos
VIDEO_LOCAL_UPLOAD_DIR=uploads/videos
VIDEO_COVER_DIR=uploads/covers
ATTACHMENT_LOCAL_UPLOAD_DIR=uploads/attachments

# Image host
IMAGEHOST_API_URL=https://api.xinyew.cn/api/jdtc
IMAGEHOST_TIMEOUT=60000

# Cloudflare R2 / S3-compatible storage
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your_bucket_name_here
R2_ACCOUNT_ID=your_account_id_here
R2_REGION=auto
R2_PUBLIC_URL=

# Video chunk uploads
VIDEO_CHUNK_TEMP_DIR=uploads/chunks
VIDEO_CHUNK_SIZE=3145728
VIDEO_CHUNK_CLEANUP_INTERVAL=1800000
VIDEO_CHUNK_EXPIRE_TIME=7200000

# Video transcoding
VIDEO_TRANSCODING_ENABLED=true
FFMPEG_PATH=/app/bin/ffmpeg
FFPROBE_PATH=/app/bin/ffprobe
VIDEO_TRANSCODING_MAX_THREADS=4
